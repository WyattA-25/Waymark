# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Supabase project (Settings > API). Safe to expose in the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google AI Studio key for Gemini chat. Server-side only.
GEMINI_API_KEY=your-gemini-key

# Recreation.gov RIDB key (https://ridb.recreation.gov). Server-side only.
RECREATION_GOV_API_KEY=your-ridb-key

# Optional: YouTube Data API v3 key (Google Cloud Console). Server-side only.
# Video search scrapes the public results page by default; this key is only a fallback.
YOUTUBE_API_KEY=your-youtube-key
